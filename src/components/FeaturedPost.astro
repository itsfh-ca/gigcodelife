---
// The large split hero card for the newest post.
import type { Post } from '../lib/posts';
import { formatDate } from '../lib/format';
import PostMedia from './PostMedia.astro';

interface Props {
  post: Post;
}

const { post } = Astro.props;
---

<a
  href={`/posts/${post.id}`}
  class="group grid grid-cols-2 max-sm:grid-cols-1 min-h-105 max-sm:min-h-0 mb-6 bg-white rounded-card overflow-hidden shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-all duration-200"
>
  <PostMedia post={post} eager class="min-h-80 max-sm:min-h-55 max-sm:aspect-16/10" markClass="text-[48px]" />
  <div class="flex flex-col p-12 max-sm:p-6">
    <span class="text-eyebrow uppercase text-gray-500 mb-3">{post.data.category}</span>
    <h2 class="text-h1 text-ink mt-1 group-hover:text-blue-500 transition-colors">{post.data.title}</h2>
    <span class="text-caption text-gray-400 mt-auto max-sm:mt-6 pt-8 max-sm:pt-0">{formatDate(post.data.pubDate)}</span>
  </div>
</a>
