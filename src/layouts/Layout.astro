---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
  image?: string;
  imageAlt?: string;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead {...Astro.props} />
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50 text-ink font-sans antialiased">
    <Header />
    <div class="flex-1">
      <slot />
    </div>
    <Footer />
  </body>
</html>
