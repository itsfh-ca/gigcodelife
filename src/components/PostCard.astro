---
// A post tile for the homepage grid.
import type { Post } from '../lib/posts';
import { formatDate } from '../lib/format';
import PostMedia from './PostMedia.astro';

interface Props {
  post: Post;
}

const { post } = Astro.props;
---

<a
  href={`/posts/${post.id}`}
  class="group flex flex-col bg-white rounded-card overflow-hidden shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-all duration-200"
>
  <PostMedia post={post} class="aspect-3/2" markClass="text-h3" />
  <div class="flex flex-col flex-1 pt-6 px-6 pb-8">
    <span class="text-eyebrow uppercase text-gray-500 mb-3">{post.data.category}</span>
    <h3 class="text-h3 text-ink mb-6 group-hover:text-blue-500 transition-colors">{post.data.title}</h3>
    <span class="text-caption text-gray-400 mt-auto">{formatDate(post.data.pubDate)}</span>
  </div>
</a>
