---
import { SITE_NAME, NAV_LINKS } from '../consts';
---

<header class="sticky top-0 z-20 bg-white/85 backdrop-blur-xl border-b border-gray-200">
  <div class="mx-auto max-w-300 px-8 max-sm:px-5 h-16 flex items-center justify-between">
    <a href="/" class="text-h3 tracking-tight text-ink">{SITE_NAME}</a>
    <nav class="flex gap-8 items-center">
      {NAV_LINKS.map((link) => (
        <a href={link.href} class="text-small font-medium text-gray-500 hover:text-ink">{link.label}</a>
      ))}
    </nav>
  </div>
</header>
