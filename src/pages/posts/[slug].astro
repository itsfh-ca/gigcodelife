---
import { render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Prose from '../../components/Prose.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getPublishedPosts, relatedPosts } from '../../lib/posts';
import { formatDate, readingTime } from '../../lib/format';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, posts },
  }));
}

const { post, posts } = Astro.props;
const { Content } = await render(post);
const related = relatedPosts(posts, post.id);
---

<Layout
  title={post.data.title}
  description={post.data.description}
  type="article"
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  author={post.data.author}
>
  <main class="mx-auto max-w-173 px-8 max-sm:px-5 pt-10 max-sm:pt-8 pb-16 max-sm:pb-12">
    <nav class="flex items-center gap-2 text-small text-gray-400" aria-label="Breadcrumb">
      <a href="/" class="text-gray-400 hover:text-ink">gigcodelife</a>
      <span aria-hidden="true">/</span>
      <span class="text-ink overflow-hidden text-ellipsis whitespace-nowrap">{post.data.title}</span>
    </nav>

    <span class="block mt-6 text-eyebrow uppercase text-gray-500">{post.data.category}</span>
    <h1 class="text-h1 max-sm:text-h2 text-ink my-4">{post.data.title}</h1>

    <div class="flex items-center justify-between pb-6 border-b border-gray-200 mb-8">
      <span class="text-small text-gray-500">
        {post.data.author} · {formatDate(post.data.pubDate)} · {readingTime(post.body)}
      </span>
      <div class="flex gap-2">
        <button class="w-9 h-9 rounded-full inline-flex items-center justify-center text-ink hover:bg-gray-100 transition-colors" type="button" aria-label="Save" title="Save">
          <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
        </button>
        <button class="w-9 h-9 rounded-full inline-flex items-center justify-center text-ink hover:bg-gray-100 transition-colors" type="button" aria-label="Share" title="Share">
          <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        </button>
      </div>
    </div>

    {post.data.image && (
      <div class="aspect-video rounded-3xl overflow-hidden bg-gray-100 mb-10">
        <img src={post.data.image} alt={post.data.imageAlt ?? ''} loading="eager" class="w-full h-full object-cover" />
      </div>
    )}

    <Prose>
      <Content />
    </Prose>

    <RelatedPosts posts={related} />
  </main>
</Layout>
